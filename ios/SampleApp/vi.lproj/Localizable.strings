"holiday_detail_ram_act_2" = "Tụng kinh hoặc nghe kinh; nhiều nhà ăn chay trong ngày.";
"holiday_detail_ram_act_3" = "Bố thí, phóng sinh — việc nhỏ mở đầu năm từ bi.";
"holiday_detail_ram_history" = "Rằm Phật giáo hòa với quan niệm dân gian “trăng đầu năm”; ở đồng bằng, rằm Giêng thành ngày hội chùa và sum họp.";
"holiday_detail_ram_origin" = "Từ quan sát nguyệt Mahayana và tục làng Việt lấy trăng làm điểm hẹn cộng đồng.";

"holiday_detail_doan_meaning" = "Đoan Ngọ ở giữa hè: thanh lọc cơ thể, bếp và nhà cửa trước lúc nắng và côn trùng đạt đỉnh.";
"holiday_detail_doan_act_1" = "Ăn chua ngâm, trái chín để “giải nhiệt”.";
"holiday_detail_doan_act_2" = "Lau bếp, quét góc, thay lá thuốc xông đuổi côn trùng.";
"holiday_detail_doan_act_3" = "Một số nhà cúng giữa trưa đánh dấu điểm giữa ngày hạ chí.";
"holiday_detail_doan_history" = "Tục mồng 5 tháng 5 có ở nhiều nước Đông Á; ở Việt Nam gắn thêm kinh nghiệm nhà nông diệt sâu bọ và thảo dược.";
"holiday_detail_doan_origin" = "Hợp lý vệ sinh mùa hè với tên dân gian như “Tết giết sâu bọ”.";

"holiday_detail_vulan_meaning" = "Vu Lan đặt tình hiếu: nhớ cha mẹ đang tại thế và đã khuất, cộng đồng mở lòng với chúng sinh trong khung từ bi Ullambana.";
"holiday_detail_vulan_act_1" = "Thăm cha mẹ, tặng quà, làm lành chuyện cũ.";
"holiday_detail_vulan_act_2" = "Cúng cơm, muối, áo tại chùa cho tổ tiên và vong linh.";
"holiday_detail_vulan_act_3" = "Tham gia tụng kinh chung hoặc lễ phóng sinh do chùa tổ chức.";
"holiday_detail_vulan_history" = "Truyện Ullambana theo Phật giáo đến Việt Nam; rằm tháng Bảy chồng bài vị gia tiên, tục cúng cô hồn và bếp cơm từ thiện.";
"holiday_detail_vulan_origin" = "Từ nghĩa cứu mẹ treo ngược trong kinh, được Đông Á đọc thành lễ báo ân và đại xá tháng bảy.";

"holiday_detail_trungthu_meaning" = "Trung Thu xoay quanh trăng rằm, trẻ em và đồ tròn tượng sum họp dưới trời trong.";
"holiday_detail_trungthu_act_1" = "Rước đèn, múa lân, ngắm trăng sân thượng hoặc sân nhà.";
"holiday_detail_trungthu_act_2" = "Biếu bánh nướng, bánh dẻo giữa họ hàng và đồng nghiệp.";
"holiday_detail_trungthu_act_3" = "Tặng đồ chơi, hoa quả cho trẻ; nhiều trường tổ chức hội rằm.";
"holiday_detail_trungthu_history" = "Họa tiết Tống từ giao thương; Việt Nam thêm đèn kéo quân, kiểu bánh địa phương và chợ đèn đông đúc.";
"holiday_detail_trungthu_origin" = "Trăng rằm tháng tám âm và lễ tạ mùa hè trước vụ đông.";

"holiday_detail_304_meaning" = "30/4 đánh dấu chấm hết chia cắt chiến tranh và mở kể chuyện một quốc gia thống nhất cho hàng triệu người.";
"holiday_detail_304_act_1" = "Diễu binh, lễ thượng cờ, bài phát biểu truyền hình ở các đô thị.";
"holiday_detail_304_act_2" = "Nhiều người về quê hoặc thăm di tích gắn 1975.";
"holiday_detail_304_history" = "Sài Gòn được giải phóng 30/4/1975 kết thúc giai đoạn chiến chính; ngày được cố định là lễ Thống nhất.";
"holiday_detail_304_origin" = "Nghi lễ nhà nước sau thống nhất để neo ký ức dân tộc vào một ngày dương lịch.";

"holiday_detail_105_meaning" = "1/5 đồng bộ Việt Nam với ngôn ngữ quyền lao động quốc tế, đồng thời ghi nhận lao động trong nước.";
"holiday_detail_105_act_1" = "Công đoàn, doanh nghiệp tổ chức khen thưởng hoặc dã ngoại.";
"holiday_detail_105_act_2" = "Nghỉ công cộng; một số thành phố có ca nhạc hoặc hội chợ công viên.";
"holiday_detail_105_history" = "Ngày Quốc tế Lao động lan từ phong trào Chicago và châu Âu thế kỷ XIX; Việt Nam nghỉ lễ theo thời hiện đại.";
"holiday_detail_105_origin" = "Truyền thống Quốc tế Nhị định 1/5 là ngày đoàn kết người lao động.";

"holiday_detail_209_meaning" = "Quốc khánh kỷ niệm bản Tuyên ngôn độc lập ở Ba Đình và câu chuyện mở nước hiện đại.";
"holiday_detail_209_act_1" = "Lễ thượng cờ Hà Nội và các tỉnh; pháo hoa nơi được phép.";
"holiday_detail_209_act_2" = "Gia đình dã ngoại hoặc xem truyền hình; cơ quan đóng cửa cả nước.";
"holiday_detail_209_history" = "Bài diễn văn 2/9/1945 là mốc; lễ cố định sau 1954 và sau thống nhất.";
"holiday_detail_209_origin" = "Gắn với Cách mạng tháng Tám lật chính quyền sau Nhật, mở ra tuyên bố độc lập.";
