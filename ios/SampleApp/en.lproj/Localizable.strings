"holiday_tet_short" = "Lunar New Year — family reunion, ancestral worship.";
"holiday_tet_desc" = "Tết Nguyên Đán marks the Vietnamese Lunar New Year. Families clean homes, prepare bánh chưng, visit ancestors’ altars, exchange wishes for luck, and welcome the new lunar year together.";

"holiday_ram_name" = "Rằm tháng Giêng";
"holiday_ram_short" = "Full moon of the first lunar month — prayer and offerings.";
"holiday_ram_desc" = "The full moon of the first lunar month is an important day for visiting pagodas, making offerings, and praying for peace and prosperity in the year ahead.";

"holiday_doan_ngo_name" = "Tết Đoan Ngọ";
"holiday_doan_ngo_short" = "Mid-year festival — cleansing and warding off pests.";
"holiday_doan_ngo_desc" = "Đoan Ngọ (5/5 lunar) is a traditional mid-year day to purify the body and home, eat fermented foods, and ward off insects and bad luck as summer intensifies.";

"holiday_vu_lan_name" = "Vu Lan (Rằm tháng Bảy)";
"holiday_vu_lan_short" = "Filial piety — honoring parents and ancestors.";
"holiday_vu_lan_desc" = "The full moon of the seventh lunar month is associated with Vu Lan, a time to express gratitude to parents and remember ancestors through offerings and compassionate acts.";

